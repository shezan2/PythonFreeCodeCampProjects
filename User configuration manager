def add_setting(settings_dict, new_settings):
    key = new_settings[0]
    value = new_settings[1]
    key = key.lower()
    value = value.lower()
    if key in settings_dict:
        return(f"Setting '{key}' already exists! Cannot add a new setting with this name.")
    else:
        settings_dict[key] = value
        return(f"Setting '{key}' added with value '{value}' successfully!")

def update_setting(settings_dict, new_settings):
    key = new_settings[0]
    value = new_settings[1]
    key = key.lower()
    value = value.lower()
    if key in settings_dict:
        settings_dict[key] = value
        return(f"Setting '{key}' updated to '{value}' successfully!")
    else:
        return(f"Setting '{key}' does not exist! Cannot update a non-existing setting.")

def delete_setting(settings_dict, key):
    key = key.lower()
    if key in settings_dict:
        del settings_dict[key]
        return(f"Setting '{key}' deleted successfully!")
    else:
        return("Setting not found!")

def view_settings(settings_dict):
    if not settings_dict:
        return("No settings available.")
    else:
        output = "Current User Settings:"
        for key in settings_dict:
            value = settings_dict[key]
            output += f"\n{key.capitalize()}: {value}"  
        output += "\n"  
        return output    
